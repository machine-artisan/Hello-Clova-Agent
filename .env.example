# LLM API 서버 설정
# vLLM 로컬 서버 기본값: http://localhost:8000/v1
LLM_API_BASE=http://localhost:8000/v1

# vLLM은 API 키 불필요 (EMPTY 유지)
LLM_API_KEY=EMPTY

# 사용할 모델명 (vLLM에 로드된 모델명과 일치해야 함)
LLM_MODEL=naver-hyperclovax/HyperCLOVA-X-SEED-Instruct-3B

# Ollama 사용 시 변경:
# LLM_API_BASE=http://localhost:11434/v1
# LLM_MODEL=hcx-seed:3b
