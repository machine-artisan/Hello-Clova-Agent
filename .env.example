# ── LLM API 서버 설정 ─────────────────────────────────────────────────────────
LLM_API_BASE=http://localhost:8000/v1
LLM_API_KEY=EMPTY

# ── 모델 선택 (용도에 맞게 주석 해제) ────────────────────────────────────────

# [기본] HyperCLOVA X SEED Instruct 3B — vLLM, fp16, ~8GB VRAM
LLM_MODEL=naver-hyperclovax/HyperCLOVA-X-SEED-Instruct-3B

# [국산 LLM 고품질] HyperCLOVA X SEED Think-14B — vLLM + 4-bit 양자화, ~8-10GB VRAM (16GB T4 가능)
# LLM_MODEL=naver-hyperclovax/HyperCLOVA-X-SEED-Think-14B
# → start_vllm.sh 실행 시 LLM_QUANTIZATION=bitsandbytes LLM_DTYPE=bfloat16 bash setup/start_vllm.sh

# [공공기관 대용량] HyperCLOVA X SEED Think-32B — vLLM + 4-bit, ~18GB VRAM (A100 권장)
# LLM_MODEL=naver-hyperclovax/HyperCLOVA-X-SEED-Think-32B

# [대안] Qwen2.5-7B-Instruct — vLLM, fp16, ~14GB VRAM
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── Ollama 환경 (Colab 기본값) ────────────────────────────────────────────────
# LLM_API_BASE=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b
# 주의: HyperCLOVA X SEED는 Ollama 공식 레지스트리 미등록 → GGUF Modelfile 필요
